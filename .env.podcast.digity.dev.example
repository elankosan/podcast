# Target deployment: podcast.digity.dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=podcast

# Existing shared PostgreSQL connection (required in existing-infra mode)
EXTERNAL_DATABASE_URL=postgresql://postgres:change-me-strong@promethea-db:5432/podcast
EXTERNAL_DB_NETWORK=promethea_promethea_internal

# Existing Traefik docker network and cert resolver
TRAEFIK_DOCKER_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=letsencrypt

NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/change-me-neo4j

SECRET_KEY=change-me-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

KIMI_API_KEY=sk-kimi-xxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

REDIS_URL=redis://redis:6379/0

ACME_EMAIL=ops@digity.dev
DOMAIN=podcast.digity.dev
API_SUBDOMAIN=api

NEXT_PUBLIC_API_URL=https://api.podcast.digity.dev
ENVIRONMENT=production
LOG_LEVEL=INFO
MAF_WORKFORCE_PATH=/app/workforce.yaml
