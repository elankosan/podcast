# ============================================================
# Multi-Lingual Podcast — Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database (PostgreSQL) ---
# Used by the FastAPI backend and docker-compose postgres service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=podcast
# Full connection URL for SQLAlchemy / Alembic
DATABASE_URL=postgresql://postgres:password@postgres:5432/podcast

# --- Knowledge Graph (Neo4j) ---
# Neo4j authentication in USER/PASSWORD format
NEO4J_USER=neo4j
NEO4J_PASSWORD=podcast_password
# Bolt URI used by the backend driver
NEO4J_URI=bolt://neo4j:7687
# Combined auth string for Neo4j containers (neo4j/PASSWORD)
NEO4J_AUTH=neo4j/podcast_password

# --- Authentication (JWT) ---
# Generate a strong random secret for production, e.g.:
#   openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
# JWT signing algorithm
ALGORITHM=HS256
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Kimi LLM ---
# API key for Kimi (or OpenAI-compatible provider)
KIMI_API_KEY=sk-kimi-...
# Base URL for the Kimi API (leave empty for default OpenAI endpoint)
KIMI_BASE_URL=https://api.moonshot.cn/v1
# Default model identifier for agent inference
KIMI_MODEL=moonshot-v1-8k

# --- Cache (Redis) ---
# Redis connection URI used by the backend for caching and job queues
REDIS_URL=redis://redis:6379/0

# --- Reverse Proxy (Traefik) ---
# Email used for Let's Encrypt ACME registration
ACME_EMAIL=admin@example.com
# Primary domain for the application
DOMAIN=example.com
# Subdomain for the API (e.g. api.example.com)
API_SUBDOMAIN=api

# --- Frontend (Next.js) ---
# Public URL the browser uses to reach the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Runtime environment: development | staging | production
ENVIRONMENT=development
# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# --- MAF Integration ---
# Absolute path inside the API container to the workforce definition
MAF_WORKFORCE_PATH=/app/workforce.yaml

# --- Optional / Advanced ---
# Neo4j APOC plugin memory settings (docker-compose)
NEO4J_dbms_memory_heap_max__size=1G
# OAuth2 provider settings (if using external OAuth)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=
